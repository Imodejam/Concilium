# Concilium — example env vars (copy to .env and fill in real values)

# API server
API_PORT=7001
API_TOKEN=change-me-bearer-token-for-api-clients

# Anthropic (default LLM provider)
ANTHROPIC_API_KEY=

# OpenAI (optional fallback)
OPENAI_API_KEY=

# Telegram bot
TELEGRAM_BOT_TOKEN=
# comma-separated list of allowed Telegram user_ids
TELEGRAM_ALLOWED_USERS=

# Frontend
WEB_PORT=7002
VITE_API_URL=http://localhost:7001
# Comma-separated list of hostnames the Vite dev server will accept (empty = none).
# When you put Concilium behind a reverse proxy, put the public hostname here.
WEB_ALLOWED_HOSTS=

# Storage path (root of the .md filesystem db)
DATA_DIR=./data

# Max rounds the Praeses can run before being forced to CONCLUDE
MAX_ROUNDS=3
